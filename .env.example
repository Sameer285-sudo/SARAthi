# ── Database ──────────────────────────────────────────────────────────────────
# Default (no setup needed): SQLite file in the project root
# DATABASE_URL=sqlite:///./pds360.db

# PostgreSQL (when running with Docker Compose or a local Postgres instance):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pds360

# ── AI Credentials (optional) ─────────────────────────────────────────────────
# Without these the system uses built-in rule-based fallbacks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Twilio (optional — IVR voice calling) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public URL for Twilio webhooks (use ngrok for local dev: ngrok http 8005)
PUBLIC_BASE_URL=http://localhost:8005
